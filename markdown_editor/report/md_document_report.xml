<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- QWeb template for Markdown Document PDF -->
    <!-- Verwendet web.external_layout: Odoo-Standard-Header/Footer, zuverlässig mit wkhtmltopdf -->
    <template id="report_md_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <!-- Inline CSS: wkhtmltopdf ignoriert externe Stylesheets weitgehend -->
                        <style>
                            /* Basis-Typografie */
                            body {
                                font-family: "DejaVu Sans", Arial, sans-serif;
                                font-size: 11pt;
                                color: #1a1a1a;
                                line-height: 1.6;
                            }

                            /* Dokument-Titelbereich */
                            .md-doc-header {
                                border-bottom: 2px solid #97d21d;
                                padding-bottom: 10px;
                                margin-bottom: 18px;
                            }
                            .md-doc-header h1 {
                                font-size: 22pt;
                                font-weight: bold;
                                margin: 0 0 6px 0;
                                color: #1a1a1a;
                            }
                            .md-doc-meta {
                                font-size: 9pt;
                                color: #555;
                                display: flex;
                                gap: 20px;
                            }
                            .md-doc-meta span::before {
                                font-weight: bold;
                                color: #333;
                            }

                            /* Überschriften */
                            h1, h2, h3, h4, h5, h6 {
                                font-family: "DejaVu Sans", Arial, sans-serif;
                                color: #1a1a1a;
                                margin-top: 20px;
                                margin-bottom: 8px;
                                line-height: 1.3;
                            }
                            h1 { font-size: 18pt; border-bottom: 1px solid #ddd; padding-bottom: 4px; }
                            h2 { font-size: 15pt; border-bottom: 1px solid #eee; padding-bottom: 3px; }
                            h3 { font-size: 13pt; }
                            h4 { font-size: 11pt; }

                            /* Fließtext */
                            p { margin: 0 0 10px 0; }

                            /* Code – inline */
                            code {
                                font-family: "DejaVu Sans Mono", "Courier New", monospace;
                                font-size: 9.5pt;
                                background-color: #f3f4f6;
                                border: 1px solid #e1e4e8;
                                border-radius: 3px;
                                padding: 1px 4px;
                                color: #24292e;
                            }

                            /* Code-Blöcke */
                            pre {
                                font-family: "DejaVu Sans Mono", "Courier New", monospace;
                                font-size: 9pt;
                                background-color: #f6f8fa;
                                border: 1px solid #e1e4e8;
                                border-left: 4px solid #97d21d;
                                border-radius: 4px;
                                padding: 10px 14px;
                                margin: 12px 0;
                                white-space: pre-wrap;
                                word-break: break-word;
                                color: #24292e;
                                page-break-inside: avoid;
                            }
                            pre code {
                                background: none;
                                border: none;
                                padding: 0;
                                font-size: inherit;
                            }

                            /* Blockquote */
                            blockquote {
                                border-left: 4px solid #97d21d;
                                margin: 12px 0;
                                padding: 6px 14px;
                                background-color: #f9fafb;
                                color: #555;
                                font-style: italic;
                            }

                            /* Listen */
                            ul, ol {
                                margin: 0 0 10px 0;
                                padding-left: 24px;
                            }
                            li { margin-bottom: 4px; }

                            /* Tabellen */
                            table {
                                border-collapse: collapse;
                                width: 100%;
                                margin: 12px 0;
                                font-size: 10pt;
                                page-break-inside: avoid;
                            }
                            th {
                                background-color: #97d21d;
                                color: #1a1a1a;
                                font-weight: bold;
                                text-align: left;
                                padding: 7px 10px;
                                border: 1px solid #ccc;
                            }
                            td {
                                padding: 6px 10px;
                                border: 1px solid #ddd;
                                vertical-align: top;
                            }
                            tr:nth-child(even) td {
                                background-color: #f9fafb;
                            }

                            /* Trennlinie */
                            hr {
                                border: none;
                                border-top: 1px solid #ddd;
                                margin: 16px 0;
                            }

                            /* Links */
                            a { color: #0969da; text-decoration: none; }

                            /* Seitenumbruch vor H1 im Fließtext (nicht beim ersten) */
                            .md-doc-content h1 { page-break-before: auto; }
                        </style>

                        <!-- Dokumentkopf mit Metadaten -->
                        <div class="md-doc-header">
                            <h1><t t-esc="doc.name"/></h1>
                            <div class="md-doc-meta">
                                <span><b>Autor: </b><t t-esc="doc.owner_id.name or ''"/></span>
                                <span><b>Version: </b><t t-esc="doc.current_version"/></span>
                                <span>
                                    <b>Status: </b>
                                    <t t-if="doc.state == 'draft'">Entwurf</t>
                                    <t t-elif="doc.state == 'published'">Veröffentlicht</t>
                                    <t t-elif="doc.state == 'archived'">Archiviert</t>
                                </span>
                                <span><b>Datum: </b><t t-esc="doc.write_date.strftime('%d.%m.%Y') if doc.write_date else ''"/></span>
                            </div>
                        </div>

                        <!-- Dokumentinhalt -->
                        <div class="md-doc-content">
                            <t t-out="doc.content_html"/>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <!-- Report action definition -->
    <record id="md_document_pdf" model="ir.actions.report">
        <field name="name">x.md.document.name</field>
        <field name="model">x.md.document</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">markdown_editor.report_md_document</field>
        <field name="report_file">object.name</field>
        <!-- binding_model_id entfernt: Export-Button ist im Form-Header -->
    </record>
</odoo>
