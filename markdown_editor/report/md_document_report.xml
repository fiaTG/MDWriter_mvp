<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="report_md_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">

                <!-- ============================================================
                     BRANDING-KONFIGURATION (zur Dokumentation)
                     Für andere Firmen: Werte im <style>-Block unten anpassen.
                     Gesuchte Stellen mit "BRAND:" kommentiert.
                     ============================================================ -->
                <t t-set="brand_company">Trendtec AG</t>
                <t t-set="brand_logo">/markdown_editor/static/description/icon.svg</t>

                <div class="page">
                    <style>
                        /* === BRAND: Fonts laden (wkhtmltopdf lädt via HTTP) === */
                        @font-face {
                            font-family: 'Mulish';
                            src: url('/markdown_editor/static/src/fonts/Mulish/Mulish-VariableFont_wght.ttf') format('truetype');
                            font-weight: 100 900;
                        }
                        @font-face {
                            font-family: 'JetBrains Mono';
                            src: url('/markdown_editor/static/src/fonts/JetBrains_Mono/JetBrainsMono-VariableFont_wght.ttf') format('truetype');
                            font-weight: 100 800;
                        }

                        @page { margin: 18mm 15mm 18mm 15mm; }

                        body {
                            font-family: Mulish, Arial, sans-serif; /* BRAND: font */
                            font-size: 11pt;
                            color: #1a1a1a;                          /* BRAND: brand_dark */
                            line-height: 1.65;
                            margin: 0;
                        }

                        /* ---- Seiten-Header ---- */
                        .pdf-header {
                            display: flex;
                            justify-content: space-between;
                            align-items: center;
                            padding-bottom: 10px;
                            border-bottom: 3px solid #97d21d;       /* BRAND: brand_primary */
                            margin-bottom: 20px;
                        }
                        .pdf-header img { height: 36px; }
                        .pdf-company {
                            font-size: 9.5pt;
                            font-weight: 600;
                            color: #5a6370;                          /* BRAND: brand_muted */
                        }

                        /* ---- Dokumentkopf ---- */
                        .pdf-doc-title {
                            font-size: 20pt;
                            font-weight: 700;
                            color: #1a1a1a;                          /* BRAND: brand_dark */
                            margin: 0 0 6px 0;
                        }
                        .pdf-doc-meta {
                            font-size: 9pt;
                            color: #5a6370;                          /* BRAND: brand_muted */
                            margin-bottom: 20px;
                            padding-bottom: 14px;
                            border-bottom: 1px solid #e0e0e0;        /* BRAND: brand_border */
                        }

                        /* ---- Überschriften ---- */
                        h1, h2, h3, h4, h5, h6 {
                            font-family: Mulish, Arial, sans-serif;  /* BRAND: font */
                            color: #97d21d;                           /* BRAND: brand_primary */
                            margin-top: 1.4em;
                            margin-bottom: 0.4em;
                        }
                        h1 {
                            font-size: 16pt;
                            border-bottom: 1.5px solid #97d21d;      /* BRAND: brand_primary */
                            padding-bottom: 4px;
                        }
                        h2 { font-size: 13pt; }
                        h3 { font-size: 11.5pt; }

                        /* ---- Absätze + Listen ---- */
                        p { margin: 0.5em 0; }
                        ul, ol { padding-left: 1.5em; margin: 0.5em 0; }
                        li { margin: 0.2em 0; }

                        /* ---- Code ---- */
                        code {
                            font-family: JetBrains Mono, Courier New, monospace; /* BRAND: font_code */
                            font-size: 9pt;
                            background: #f5f5f5;                     /* BRAND: brand_bg_code */
                            padding: 1px 5px;
                            border-radius: 2px;
                        }
                        pre {
                            font-family: JetBrains Mono, Courier New, monospace; /* BRAND: font_code */
                            font-size: 9pt;
                            background: #f5f5f5;                     /* BRAND: brand_bg_code */
                            border-left: 3px solid #97d21d;          /* BRAND: brand_primary */
                            padding: 10px 14px;
                            white-space: pre-wrap;
                            word-break: break-word;
                            page-break-inside: avoid;
                            margin: 0.8em 0;
                        }
                        pre code { background: none; padding: 0; }

                        /* ---- Tabellen ---- */
                        table { border-collapse: collapse; width: 100%; margin: 1em 0; font-size: 10pt; }
                        th {
                            background: #97d21d;                     /* BRAND: brand_primary */
                            color: #fff;
                            font-weight: 600;
                            padding: 5px 8px;
                            text-align: left;
                        }
                        td { padding: 4px 8px; border-bottom: 1px solid #e0e0e0; } /* BRAND: brand_border */
                        tr:nth-child(even) td { background: #fafafa; }

                        /* ---- Sonstiges ---- */
                        blockquote {
                            border-left: 4px solid #97d21d;          /* BRAND: brand_primary */
                            margin: 0.8em 0;
                            padding: 4px 14px;
                            color: #5a6370;                          /* BRAND: brand_muted */
                            font-style: italic;
                        }
                        a { color: #97d21d; }                        /* BRAND: brand_primary */
                        hr { border: none; border-top: 1px solid #e0e0e0; margin: 1.2em 0; } /* BRAND: brand_border */
                        img { max-width: 100%; }

                        /* ---- Seiten-Footer ---- */
                        .pdf-footer {
                            margin-top: 32px;
                            padding-top: 8px;
                            border-top: 1px solid #e0e0e0;           /* BRAND: brand_border */
                            font-size: 8.5pt;
                            color: #5a6370;                          /* BRAND: brand_muted */
                            display: flex;
                            justify-content: space-between;
                        }
                    </style>

                    <!-- Seiten-Header mit Logo und Firmenname -->
                    <div class="pdf-header">
                        <img t-att-src="brand_logo" alt="Logo"/>
                        <span class="pdf-company"><t t-esc="brand_company"/></span>
                    </div>

                    <!-- Dokumentkopf: Titel + Metadaten -->
                    <div class="pdf-doc-title"><t t-esc="doc.name"/></div>
                    <div class="pdf-doc-meta">
                        Version <t t-esc="doc.current_version"/>
                        &#183; <t t-esc="doc.owner_id.name"/>
                        &#183; <t t-esc="doc.write_date.strftime('%d.%m.%Y') if doc.write_date else ''"/>
                    </div>

                    <!-- Markdown-Inhalt: direkte Methode umgeht fields.Html ORM-Verarbeitung -->
                    <div t-out="doc._get_report_html()"/>

                    <!-- Seiten-Footer -->
                    <div class="pdf-footer">
                        <span><t t-esc="brand_company"/></span>
                        <span><t t-esc="doc.name"/> &#183; v<t t-esc="doc.current_version"/></span>
                    </div>
                </div>

            </t>
        </t>
    </template>

    <!-- Report action definition -->
    <record id="md_document_pdf" model="ir.actions.report">
        <field name="name">Als PDF exportieren</field>
        <field name="model">x.md.document</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">markdown_editor.report_md_document</field>
        <field name="report_file">${object.name}</field>
        <!-- binding_model_id entfernt: Export-Button ist im Form-Header, nicht im Zahnrad-Menü -->
    </record>
</odoo>
