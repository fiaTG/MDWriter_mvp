<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- QWeb template for Markdown Document PDF -->
    <!-- Verwendet web.external_layout: Odoo-Standard-Header/Footer, zuverlässig mit wkhtmltopdf -->
    <template id="report_md_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h1><t t-esc="doc.name"/></h1>
                        <div t-out="doc.content_html"/>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <!-- Report action definition -->
    <record id="md_document_pdf" model="ir.actions.report">
        <field name="name">Als PDF exportieren</field>
        <field name="model">x.md.document</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">markdown_editor.report_md_document</field>
        <field name="report_file">document</field>
        <!-- binding_model_id entfernt: Export-Button ist im Form-Header -->
    </record>
</odoo>
