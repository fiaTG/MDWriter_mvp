<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Form view for Markdown Document -->
    <record id="view_md_document_form" model="ir.ui.view">
        <field name="name">x.md.document.form</field>
        <field name="model">x.md.document</field>
        <field name="arch" type="xml">
            <form string="Markdown‑Dokument">
                <sheet>
                    <header>
                        <button name="action_publish" type="object" string="Veröffentlichen"
                            invisible="state == 'published'" class="btn-primary"/>
                        <button name="action_set_draft" type="object" string="Zurück zu Entwurf"
                            invisible="state == 'draft'"/>
                        <button name="action_archive_doc" type="object" string="Archivieren"
                            invisible="state == 'archived'"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,published,archived"/>
                    </header>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Dokumenttitel"/></h1>
                    </div>
                    <field name="content_md" widget="markdown_editor" nolabel="1"/>
                    <notebook>
                        <page string="Metadaten" name="metadata">
                            <group>
                                <group>
                                    <field name="owner_id" readonly="1"/>
                                    <field name="current_version" readonly="1"/>
                                </group>
                                <group>
                                    <field name="create_date" readonly="1"/>
                                    <field name="write_date" readonly="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="Versionen" name="versions">
                            <div class="mb-2">
                                <button name="action_open_diff" type="object" string="Versionen vergleichen" class="btn btn-secondary btn-sm"/>
                            </div>
                            <field name="version_ids" readonly="1">
                                <list string="Versionen">
                                    <field name="version" string="Version"/>
                                    <field name="changed_by" string="Geändert von"/>
                                    <field name="changed_at" string="Geändert am"/>
                                    <field name="checksum" string="Checksumme"/>
                                    <field name="md_attachment_id" string="Markdown"/>
                                    <field name="pdf_attachment_id" string="PDF"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>

            </form>
        </field>
    </record>

    <!-- List view for Markdown Document -->
    <record id="view_md_document_list" model="ir.ui.view">
        <field name="name">x.md.document.list</field>
        <field name="model">x.md.document</field>
        <field name="arch" type="xml">
            <list string="Markdown‑Dokumente">
                <field name="name"/>
                <field name="owner_id" widget="many2one_avatar_user"/>
                <field name="state" widget="badge"
                    decoration-success="state == 'published'"
                    decoration-warning="state == 'archived'"/>
                <field name="current_version"/>
                <field name="write_date" widget="date"/>
            </list>
        </field>
    </record>

    <!-- Search view for filters -->
    <record id="view_md_document_search" model="ir.ui.view">
        <field name="name">x.md.document.search</field>
        <field name="model">x.md.document</field>
        <field name="arch" type="xml">
            <search string="Markdown‑Dokumente">
                <field name="name"/>
                <field name="owner_id"/>
                <separator/>
                <filter string="Entwürfe" name="draft_filter" domain="[('state', '=', 'draft')]"/>
                <filter string="Veröffentlicht" name="published_filter" domain="[('state', '=', 'published')]"/>
                <filter string="Archiviert" name="archived_filter" domain="[('state', '=', 'archived')]"/>
                <separator/>
                <filter string="Meine Dokumente" name="my_docs" domain="[('owner_id', '=', uid)]"/>
                <separator/>
                <filter string="Nach Status" name="group_state" context="{'group_by': 'state'}"/>
                <filter string="Nach Eigentümer" name="group_owner" context="{'group_by': 'owner_id'}"/>
            </search>
        </field>
    </record>

    <!-- Version Form View (read-only) -->
    <record id="view_md_document_version_form" model="ir.ui.view">
        <field name="name">x.md.document.version.form</field>
        <field name="model">x.md.document.version</field>
        <field name="arch" type="xml">
            <form string="Version" create="false" edit="false" delete="false">
                <header>
                    <button name="action_restore" type="object" string="Wiederherstellen" class="btn-primary" confirm="Möchtest du das Dokument auf diese Version zurücksetzen? Eine neue Version wird automatisch angelegt."/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h2><field name="version" string="Version" readonly="1"/></h2>
                    </div>
                    <group>
                        <group>
                            <field name="version" readonly="1"/>
                            <field name="changed_by" readonly="1"/>
                        </group>
                        <group>
                            <field name="changed_at" readonly="1"/>
                            <field name="checksum" readonly="1"/>
                        </group>
                    </group>
                    <group string="Anhänge">
                        <field name="md_attachment_id" readonly="1"/>
                        <field name="pdf_attachment_id" readonly="1"/>
                    </group>
                    <separator string="Markdown‑Inhalt"/>
                    <field name="content_md" widget="markdown_editor" nolabel="1" readonly="1" class="o_full_width"/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action and Menu -->
    <record id="action_md_document" model="ir.actions.act_window">
        <field name="name">Markdown‑Dokumente</field>
        <field name="res_model">x.md.document</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_md_document_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Erstelle dein erstes Markdown‑Dokument!
            </p>
            <p>
                Mit dieser App kannst du Markdown‑Dokumente erstellen, live bearbeiten
                und Versionen verwalten. Jede Änderung wird automatisch versioniert
                und mit einem Audittrail versehen.
            </p>
        </field>
    </record>

    <!-- Root Menu -->
    <menuitem id="menu_md_document_root" name="Markdown" sequence="20" web_icon="markdown_editor,static/description/icon.svg"/>

    <!-- Documents Menu -->
    <menuitem id="menu_md_document" name="Dokumente" parent="menu_md_document_root" action="action_md_document" sequence="10"/>
</odoo>